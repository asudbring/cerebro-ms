# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# Azure Database for PostgreSQL
DATABASE_URL=postgresql://cerebro_app:PASSWORD@YOUR_SERVER.postgres.database.azure.com:5432/cerebro?sslmode=require

# Azure Blob Storage (for file attachments)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_STORAGE;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net

# Microsoft Graph API (for downloading Teams/SharePoint file attachments)
# Create an Entra ID app registration with Sites.Read.All application permission
GRAPH_TENANT_ID=your-entra-tenant-id
GRAPH_CLIENT_ID=your-app-registration-client-id
GRAPH_CLIENT_SECRET=your-app-registration-client-secret

# Ingest API Key (optional — protects the ingest endpoint when called from Power Automate)
# If not set, falls back to MCP_ACCESS_KEY
# INGEST_API_KEY=your-64-char-hex-key

# MCP Server
MCP_ACCESS_KEY=your-64-char-hex-key
