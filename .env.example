# Azure OpenAI (AI Foundry)
AZURE_OPENAI_ENDPOINT=https://cerebro-openai.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# Database (Azure PostgreSQL Flexible Server)
DATABASE_URL=postgres://cerebroadmin:<password>@cerebro-db.postgres.database.azure.com:5432/cerebro?sslmode=require

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=

# Teams Bot (Bot Framework) — app registration in Entra ID tenant
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_SECRET=
TEAMS_BOT_TENANT_ID=your-entra-tenant-id
TEAMS_ALLOWED_SENDERS=    # optional, comma-separated AAD Object IDs

# Microsoft Graph (File Attachments) — app registration in Entra ID
GRAPH_TENANT_ID=your-entra-tenant-id
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
CALENDAR_USER_EMAIL=

# Note: MCP OAuth is handled by Azure API Management (validate-azure-ad-token policy)
# No MCP auth environment variables needed in the function app
